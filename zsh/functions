# Yazi Wrapper: Changes directory on exit
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# Omarchy functions (tmux layouts, compression, drives, transcoding, git worktrees, ssh forwarding)
for fn_file in ~/.local/share/omarchy/default/bash/fns/*; do
  source "$fn_file"
done

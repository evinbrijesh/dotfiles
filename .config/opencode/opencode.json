{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5": {
          "_launch": true,
          "name": "qwen3.5"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "tree *": "allow",
      "grep *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow"
    },
    "webfetch": "ask"
  },
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  }
}
